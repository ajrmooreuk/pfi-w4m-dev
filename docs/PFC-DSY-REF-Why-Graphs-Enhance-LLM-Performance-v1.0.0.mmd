graph TD
    subgraph PROBLEM["THE CORE PROBLEM"]
        P1["LLMs are stateless text predictors"]
        P2["No built-in memory, structure or relationship reasoning"]
        P3["Every prompt starts from scratch"]
        P1 --> P2 --> P3
    end

    subgraph BREAKS["Breaks Down When An Agent Needs To"]
        B1["Navigate complex interconnected domains"]
        B2["Enforce constraints and dependencies"]
        B3["Stay consistent across action chains"]
        B4["Know what it does not know"]
    end

    PROBLEM --> BREAKS

    subgraph GRAPH_DEF["WHAT IS A GRAPH"]
        G0["Nodes are things, Edges are relationships. Simple."]
    end

    BREAKS -->|"Graphs solve this"| GRAPH_DEF

    GRAPH_DEF --> G1
    GRAPH_DEF --> G2
    GRAPH_DEF --> G3
    GRAPH_DEF --> G4
    GRAPH_DEF --> G5

    subgraph G1["1 Structured Context Not Token Soup"]
        G1A["WITHOUT graph: Flat text, LLM guesses relationships"]
        G1B["WITH graph: Exact subgraph retrieved as explicit triples"]
        G1A -->|"vs"| G1B
    end

    subgraph G2["2 Precision Retrieval Not Just Similarity"]
        G2A["Vector search finds text that looks similar"]
        G2B["Graph traversal finds things actually connected"]
        G2C["For agents you want FACTS not VIBES"]
        G2A -->|"vs"| G2B --> G2C
    end

    subgraph G3["3 Bounded Reasoning"]
        G3A["Unbounded input = hallucination"]
        G3B["Graph constrains valid next steps"]
        G3C["LLM picks from known set, not free generation"]
        G3A --> G3B --> G3C
    end

    subgraph G4["4 Multi-Hop Reasoning"]
        G4A["Who manages the team that owns the service with most incidents"]
        G4B["Traverse: Incident to Service to Team to Manager"]
        G4C["Hand the LLM the answer path, not the puzzle"]
        G4A --> G4B --> G4C
    end

    subgraph G5["5 Persistent Evolving Memory"]
        G5A["Episodic: what happened"]
        G5B["Semantic: what things mean"]
        G5C["Procedural: how to do things"]
    end

    subgraph AGENT["THE AGENT-SPECIFIC PAYOFF"]
        A1["Tool Selection: graph encodes which tools apply to which states"]
        A2["Planning: graph traversal generates valid action sequences"]
        A3["Guardrails: graph constraints prevent invalid transitions"]
        A4["Context Assembly: subgraph extraction gives LLM exactly what it needs"]
        A5["Explainability: the traversal path IS the reasoning trace"]
    end

    G1 --> AGENT
    G2 --> AGENT
    G3 --> AGENT
    G4 --> AGENT
    G5 --> AGENT

    subgraph START["PRACTICAL STARTING POINTS"]
        S1["1. JSON adjacency lists: nodes and edges as plain objects"]
        S2["2. Use graph to build prompts: traverse, serialize, inject"]
        S3["3. Let LLM update the graph: tool calls that add or modify nodes"]
        S1 --> S2 --> S3
    end

    AGENT --> START

    subgraph GRAD["WHEN TO GRADUATE TO A GRAPH DB"]
        GD1["Node count exceeds what fits in a prompt"]
        GD2["Complex multi-hop queries needed at low latency"]
    end

    START --> GRAD

    SUMMARY["Graphs turn the LLM from a TEXT GUESSER into a STRUCTURE-AWARE REASONER"]

    GRAD --> SUMMARY

    classDef problem fill:#2d1b2e,stroke:#e74c3c,color:#f8d7da
    classDef graphnode fill:#1b2d2e,stroke:#1abc9c,color:#d1ecf1
    classDef agent fill:#2e2b1b,stroke:#f39c12,color:#fff3cd
    classDef start fill:#1b1f2e,stroke:#3498db,color:#cce5ff
    classDef summary fill:#0d1117,stroke:#a78bfa,color:#e0d4fc

    class P1,P2,P3,B1,B2,B3,B4 problem
    class G0,G1A,G1B,G2A,G2B,G2C,G3A,G3B,G3C,G4A,G4B,G4C,G5A,G5B,G5C graphnode
    class A1,A2,A3,A4,A5 agent
    class S1,S2,S3,GD1,GD2 start
    class SUMMARY summary
