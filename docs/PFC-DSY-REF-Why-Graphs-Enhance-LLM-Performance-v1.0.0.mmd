    classDef graph fill:#1b2d2e,stroke:#1abc9c,color:#d1ecf1
    classDef benefit fill:#1b2e1f,stroke:#2ecc71,color:#d4edda
    classDef agent fill:#2e2b1b,stroke:#f39c12,color:#fff3cd
    classDef start fill:#1b1f2e,stroke:#3498db,color:#cce5ff
    classDef summary fill:#0d1117,stroke:#a78bfa,color:#e0d4fc,font-weight:bold

    class P1,P2,P3,B1,B2,B3,B4 problem
    class G0,G1A,G1B,G1C,G2A,G2B,G2C,G3A,G3B,G3C,G4A,G4B,G4C,G5A,G5B,G5C graph
    class A1,A2,A3,A4,A5 agent
    class S1,S2,S3,GD1,GD2 start
    class SUMMARY summary
